---
import { Image as AstroImage } from "astro:assets";
import type { ComponentProps } from "astro/types";
import { z } from "astro/zod";

const fitSchema = z.enum(["contain", "cover", "fill"]).optional().default("contain")

const PropSchema = z.intersection(z.custom<ComponentProps<typeof AstroImage>>(), z.object({
  caption: z.string().optional(),
  fit: fitSchema
}))

type Props = z.input<typeof PropSchema>
const props = PropSchema.parse(Astro.props)

const styles = [
  `object-fit: ${props.fit}`,
].filter(Boolean).join("; ");
---

<ds-image>
  <AstroImage
    {...props}
    style={styles}
    loading="eager"
    decoding="async"
    class="ds-image-inner"
  />
</ds-image>

<script>
  import { registerResource } from "./utils/resource";

  export class DsImage extends HTMLElement {
    connectedCallback() {
      const img = this.querySelector("img");
      if (!img) return;

      const handle = registerResource(this);

      if (img.complete) {
        handle.ready();
      } else {
        img.addEventListener("load", () => handle.ready(), { once: true });
        img.addEventListener("error", (e) => handle.error({ ...e, name: "Image loading error"}), { once: true });
      }
    }
  }

  customElements.define("ds-image", DsImage);
</script>

<style>
ds-image {
  display: contents;
}

.ds-image-inner {
  width: 100%;
  display: block;
  height: 100%;
}
</style>
