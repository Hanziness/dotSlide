---
export type OverlayLocation = 'top' | 'center' | 'bottom';
export type Alignment = 'left' | 'center' | 'right';

interface Props {
    location: OverlayLocation
    alignment: Alignment
    padding?: boolean
}
---

<ds-overlay class:list={[
    { 'top': Astro.props.location === 'top', 'bottom': Astro.props.location === 'bottom', 'vcenter': Astro.props.location === 'center'},
    { 'left': Astro.props.alignment === 'left', 'hcenter': Astro.props.alignment === 'center', 'right': Astro.props.alignment === 'right' },
    { 'padded': Astro.props.padding }
]}>
    <slot />
</ds-overlay>

<style>
ds-overlay {
    position: absolute;
    display: flex;
    flex-direction: row;
    gap: 0.5em;
}

ds-overlay.padded {
    padding: var(--ds-overlay-padding, 1em);
}

ds-overlay.top {
    top: 0;
}

ds-overlay.bottom {
    bottom: 0;
}

ds-overlay.vcenter {
    height: 100%;
    align-items: center;
}

ds-overlay.left {
    left: 0;
}

ds-overlay.hcenter {
    width: 100%;
    justify-content: center;
}

ds-overlay.right {
    right: 0;
}
</style>
