---
export type OverlayLocation = 'top' | 'center' | 'bottom';
export type Alignment = 'left' | 'center' | 'right';

interface Props {
    location: OverlayLocation
    alignment: Alignment
    padding?: boolean
}
---

<div class:list={[
    'overlay',
    { 'top': Astro.props.location === 'top', 'bottom': Astro.props.location === 'bottom', 'vcenter': Astro.props.location === 'center'},
    { 'left': Astro.props.alignment === 'left', 'hcenter': Astro.props.alignment === 'center', 'right': Astro.props.alignment === 'right' },
    { 'padded': Astro.props.padding }
]}>
    <slot />
</div>

<style>
@layer dotslide {
    div.overlay {
        position: absolute;

        display: flex;
        flex-direction: row;
        gap: .5em;
    }

    div.overlay.padded {
        padding: 1em;
    }

    div.overlay.top {
        top: 0;
    }

    div.overlay.vcenter {
        height: 100%;
        align-items: center;
    }

    div.overlay.bottom {
        bottom: 0;
    }

    div.overlay.left {
        left: 0;
    }

    div.overlay.hcenter {
        width: 100%;
        justify-content: center;
    }

    div.overlay.right {
        right: 0;
    }
}
</style>