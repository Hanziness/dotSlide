---
import { z } from "astro/zod";
import { AlignmentSchema } from ".";

const PropsSchema = z.object({
  class: z.string().optional(),
  gap: z.number().gte(0).optional().default(0.5),
  justify: AlignmentSchema.optional().default("start"),
  align: AlignmentSchema.optional().default("center"),
  mode: z.enum(["row", "column"]).optional().default("row"),
  column: z.boolean().optional(),
});

type Props = z.input<typeof PropsSchema>;

const rawProps = Astro.props;

if ("mode" in rawProps && "column" in rawProps) {
  throw new Error("Cannot specify both 'mode' and 'column'.");
}

const props = PropsSchema.parse(rawProps);
const resolvedMode = props.column === true ? "column" : props.mode;
---

<ds-flex
  class:list={[props.class]}
  gap={props.gap}
  justify={props.justify}
  align={props.align}
  mode={resolvedMode}
>
  <slot />
</ds-flex>

<style>
  ds-flex {
    display: flex;
    flex-direction: var(--flex-direction, row);
    justify-content: var(--justify, start);
    align-items: var(--align, center);
    gap: var(--gap, .5rem);
  }
</style>

<script>
  class DsFlex extends HTMLElement {
    static observedAttributes = ["gap", "justify", "align", "mode"] as const;

    attributeChangedCallback(name: typeof DsFlex.observedAttributes[number], _oldValue: string, newValue: string) {
      if (name === "gap") {
        this.style.setProperty("--gap", `${Number(newValue) ?? 0.5}rem`);
      } else if (name === "justify") {
        this.style.setProperty("--justify", newValue ?? "start");
      } else if (name === "align") {
        this.style.setProperty("--align", newValue);
      } else if (name === "mode") {
        this.style.setProperty("--flex-direction", newValue);
      }
    }
  }

  customElements.define("ds-flex", DsFlex)
</script>
