---

import Loader from "./overlay/Loader.astro";
import { generateId } from "./utils";
import "../index.css";
import KeyboardHandler from "./controls/KeyboardHandler.astro";
import SlideControls from "./controls/SlideControls.astro";

interface Props {
  /** Internal width of the slides, in pixels */
  width: number;
  /** Internal height of the slides, in pixels */
  height: number;
  /** Show on-screen navigation controls (default: true) */
  controls?: boolean;
  /** Enable keyboard navigation (default: true) */
  keyboard?: boolean;
}

export const identifier = 'slideshow' as const

const slideshowId = generateId()
const { controls = true, keyboard = true } = Astro.props;
---

<script>
import type { NavigationNode } from "./store/context/navigation";
import { createSlideshowContext } from "./store/context/slideshow";
import { generateId, logger } from "./utils";
import { RESOURCE_READY, RESOURCE_REGISTER } from "./utils/events";
import { buildNavigationSequence, updateSlideVisibility, updateStepVisibility } from "./utils/navigation";
import type { ResourceRegistrationDetail } from "./utils/resource";

type Size = {
  width: number
  height: number
}

function parseHash(hash: string): { slideIndex: number, stepIndex: number } | null {
  const match = hash.match(/^#\/(\d+)(?:\/(\d+))?$/);
  if (!match) return null;
  return {
    slideIndex: parseInt(match[1], 10) - 1, // 1 subtracted because it is treated as a 1-based index
    stepIndex: match[2] ? parseInt(match[2], 10) : 1
  };
}

function findNavigationIndex(sequence: NavigationNode[], target: { slideIndex: number, stepIndex: number }): number {
  return sequence.findIndex(node => 
    node.slideIndex === target.slideIndex && node.stepIndex === target.stepIndex
  );
}

export class Slideshow extends HTMLElement {
  /** Unique identifier of this Slideshow */
  slideshowId: string
  /** Display size of the Slideshow, in pixels */
  slideshowSize: Size
  
  private _resizeObserver?: ResizeObserver
  private _onHashChange?: () => void
  private _onResourceRegister?: (e: Event) => void
  private _onResourceReady?: (e: Event) => void

  constructor() {
    super()

    const slideWidth = this.getAttribute("data-slideshow-width")
    const slideHeight = this.getAttribute("data-slideshow-height")

    if (slideWidth === null || slideHeight === null) {
        throw new Error("Slideshow width or height is undefined")
      }

    const width = Number.parseInt(slideWidth, 10)
    const height = Number.parseInt(slideHeight, 10)

    this.slideshowSize = {
      width,
      height
    }

    this.slideshowId = this.dataset.slideshowId ?? generateId()
  }

  connectedCallback() {
    const slideshowId = this.dataset.slideshowId as string
    this._resizeObserver = new ResizeObserver((entries) => {
      if (entries.length < 1) { return; }

      const currentDimensions = this.getBoundingClientRect();
      const scaleToFitParent = Math.min(currentDimensions.width / this.slideshowSize.width, currentDimensions.height / this.slideshowSize.height)
      this.style.setProperty('--slide-scale', scaleToFitParent.toString());
    })

    const slides = [...this.querySelectorAll<HTMLElement>('ds-slide')];
    const navigationSequence = buildNavigationSequence(this);

    let initialNavigationIndex = 0;
    const hashState = parseHash(window.location.hash);
    if (hashState) {
        const idx = findNavigationIndex(navigationSequence, hashState);
        if (idx !== -1) initialNavigationIndex = idx;
    }

    const slideshowContextRef = createSlideshowContext(this, {
      id: slideshowId,
      width: this.slideshowSize.width,
      height: this.slideshowSize.height,
      navigationIndex: initialNavigationIndex,
      navigationSequence,
    })

    // Resource readiness event listeners
    this._onResourceRegister = (e: Event) => {
      const { resourceId, slideIndex } = (e as CustomEvent<ResourceRegistrationDetail>).detail;
      logger.debug(`Resource registered: ${resourceId} (slide ${slideIndex})`);

      const current = slideshowContextRef.get();

      // Revert to loading if we were already ready (late registration)
      if (current.phase === "ready") {
        slideshowContextRef.setKey("phase", "loading");
      }

      slideshowContextRef.setKey("pending", {
        ...current.pending,
        [resourceId]: { slideIndex },
      });
    };

    this._onResourceReady = (e: Event) => {
      const { resourceId } = (e as CustomEvent<ResourceRegistrationDetail>).detail;
      logger.debug(`Resource ready: ${resourceId}`);

      const { [resourceId]: _, ...remaining } = slideshowContextRef.get().pending;
      slideshowContextRef.setKey("pending", remaining);
    };

    this.addEventListener(RESOURCE_REGISTER, this._onResourceRegister);
    this.addEventListener(RESOURCE_READY, this._onResourceReady);

    // Close the registration window after synchronous connectedCallback cascade
    requestAnimationFrame(() => {
      const current = slideshowContextRef.get();
      if (current.phase === "registering") {
        slideshowContextRef.setKey("phase", "loading");
      }
    });

    // Update navigation on context changes
    slideshowContextRef.subscribe((store, oldValue) => {
      logger.debug(store)

      // Gate visibility updates until the slideshow is ready
      if (!store.ready) return;

      const { activeSlide, activeStep } = store;
      const currentSlide = slides[activeSlide];

      // On first ready, oldValue may have ready=false — do a full pass
      const prevSlide = oldValue?.ready ? oldValue.activeSlide : undefined;

      // Update Slide and Step visibilities
      updateSlideVisibility(slides, activeSlide, prevSlide);
      if (currentSlide) {
        updateStepVisibility(currentSlide, activeStep);
      }

      const hash = activeStep === 1 ? `#/${activeSlide + 1}` : `#/${activeSlide + 1}/${activeStep}`;
      
      if (window.location.hash !== hash) {
          history.replaceState(null, "", hash);
      }
    })

    // Update state on hash changes
    this._onHashChange = () => {
        const newState = parseHash(window.location.hash);
        if (newState) {
             const newIndex = findNavigationIndex(navigationSequence, newState);
             if (newIndex !== -1) {
                 slideshowContextRef.setKey("navigationIndex", newIndex);
             }
        }
    }
    window.addEventListener("hashchange", this._onHashChange);

    this.style.setProperty('--slide-width', `${this.slideshowSize.width}px`);
    this.style.setProperty('--slide-height', `${this.slideshowSize.height}px`);

    this._resizeObserver.observe(this);
  }
  
  disconnectedCallback() {
      this._resizeObserver?.disconnect();
      if (this._onHashChange) {
          window.removeEventListener("hashchange", this._onHashChange);
      }
      if (this._onResourceRegister) {
          this.removeEventListener(RESOURCE_REGISTER, this._onResourceRegister);
      }
      if (this._onResourceReady) {
          this.removeEventListener(RESOURCE_READY, this._onResourceReady);
      }
  }
}

customElements.define('ds-slideshow', Slideshow)
</script>


<style>
@layer dotslide {
  ds-slideshow {
    --fit-scale: 1;
    --slide-width: attr(data-slideshow-width px);
    --slide-height: attr(data-slideshow-height px);
    --slide-scale: attr(data-slideshow-scale, 1);

    position: relative;
    contain: layout style paint;

    scale: var(--fit-scale);
    width: 100%;
    height: 100%;

    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;

    font-family: var(--ds-font-family, system-ui, sans-serif);
    font-size: var(--ds-font-size-base, 1rem);

    /* TODO Remove this - only for debugging */
    transition: opacity 1s ease-in-out;
  }

  ds-slideshow.loading {
    opacity: 20%;
  }
}
</style>

<ds-slideshow data-slideshow-id={slideshowId} data-slideshow-width={Astro.props.width} data-slideshow-height={Astro.props.height}>
  <slot />
  {controls && <SlideControls />}
  {keyboard && <KeyboardHandler />}
  <Loader />
</ds-slideshow>
