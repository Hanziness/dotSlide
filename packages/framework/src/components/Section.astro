---

import { z } from 'astro/zod';
import { getDataTags } from '../utils'

export const PropSchema = z.object({
    level: z.number().int().min(0).max(6),
    title: z.string().optional()
})

type Props = z.output<typeof PropSchema>

// Throw an error if props are invalid
PropSchema.parse(Astro.props)
---

<div {...getDataTags(Astro.props, 'section', ['level', 'title'])} class="hidden" />

<script>
import { sectionContext } from "../store";
import { buildSectionHierarchy } from "../utils/section";

// Build section hierarchy once when DOM is ready.
// Uses a flag to ensure it only runs once even with multiple Section components.
if (!sectionContext.get().initialized) {
  // Defer to ensure all elements are in the DOM
  queueMicrotask(() => {
    if (!sectionContext.get().initialized) {
      buildSectionHierarchy();
    }
  });
}
</script>