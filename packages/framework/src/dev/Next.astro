---
import { ChevronRight } from "@lucide/astro";
---

<button slide-next>
  <ChevronRight aria-hidden="true" />
</button>

<style>
  button[slide-next] {
    border-radius: 9999px;
    background-color: white;
    padding: 0.75rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1),
                0 4px 6px -4px rgb(0 0 0 / 0.1);
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
import { useSlideshowContext } from "../store/context/slideshow"

document.querySelectorAll('button[slide-next]').forEach((btn) => {
  const ctx = useSlideshowContext(btn as HTMLElement)
  btn.addEventListener('click', () => ctx.next())
})
</script>
