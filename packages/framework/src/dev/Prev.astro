<button slide-prev class="rounded-full bg-white p-3 shadow-lg">
  <div class="i-lucide:chevron-left" />
</button>

<script>
import { useSlideshowContext } from "../store/context/slideshow"

document.querySelectorAll('button[slide-prev]').forEach((btn) => {
  const ctx = useSlideshowContext(btn as HTMLElement)
  btn.addEventListener('click', () => ctx.prev())
})
</script>
