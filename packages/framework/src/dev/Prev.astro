<button slide-prev class="rounded-full bg-white p-3 shadow-lg">
  <div class="i-lucide:chevron-left" />
</button>

<script>
import { useSlideshowContext } from "../store/context/slideshow"

document.querySelectorAll('button[slide-prev]').forEach((btn) => {
  const slideshowContext = useSlideshowContext(btn as HTMLElement)
  btn.addEventListener('click', () => {
    const currentIdx = slideshowContext.get().activeSlide
    slideshowContext.setKey('activeSlide', Math.max(0, currentIdx - 1))
  })
})
</script>
