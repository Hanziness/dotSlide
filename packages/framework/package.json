{
  "name": "@dotslide/framework",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "development": "./index.ts",
      "default": "./dist/index.ts"
    },
    "./controls": {
      "development": "./controls.ts",
      "default": "./dist/controls.ts"
    },
    "./dev": {
      "development": "./dev.ts",
      "default": "./dist/dev.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "controls.ts",
    "dev.ts"
  ],
  "keywords": [
    "dotslide",
    "astro-component"
  ],
  "scripts": {
    "build:css": "node scripts/build.mjs && unocss \"dist/src/**/*.astro\" \"dist/src/**/*.ts\" --rewrite --minify -o dist/styles.css",
    "dev": "unocss \"src/**/*.astro\" \"src/**/*.ts\" --watch -o dist/styles.css",
    "dev:setup": "wait-on dist/styles.css"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.6",
    "@unocss/cli": "66.6.1",
    "@unocss/preset-icons": "66.6.1",
    "@unocss/transformer-compile-class": "66.6.1",
    "astro": "^5.17.1",
    "unocss": "^66.6.0",
    "wait-on": "^9.0.3"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "@lucide/astro": "^0.575.0",
    "nanostores": "^1.1.0",
    "zod": "^4.3.6"
  }
}
