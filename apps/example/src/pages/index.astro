---

import { Root, Slide, Slideshow, StyleHelper } from "@dotslide/framework";
import "../global.css";
import "@dotslide/framework/themes/default.css";

import SectionWithSlide from "../components/SectionWithSlide.astro";
// Custom slides
import Title from "../components/slides/Title.astro";
---

<Root>
	<StyleHelper />
	<Slideshow width={1024} height={768}>
		<Title title="A Guide to Today's AI" author="Imre Gera" />
		<Slide>Hi there</Slide>
		<SectionWithSlide level={1} title="The basics" />
		<Slide>
			Oh look, another slide!
		</Slide>
	</Slideshow>
</Root>
