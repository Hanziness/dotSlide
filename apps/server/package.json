{
  "name": "@dotslide/server",
  "version": "0.0.1",
  "type": "module",
  "author": {
    "name": "Imre Gera",
    "url": "https://github.com/Hanziness"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun run build.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@dotslide/protocol": "workspace:*",
    "@hono/zod-validator": "0.7.6",
    "better-auth": "1.5.3",
    "drizzle-orm": "0.45.1",
    "hono": "4.12.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "drizzle-kit": "0.31.9"
  },
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./dist/app.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    }
  }
}
